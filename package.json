{
  "name": "tikclip",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "npm run lint:js && npm run lint:py && npm run lint:rust",
    "lint:js": "eslint . && npm run build",
    "lint:py": "cd sidecar && uv run ruff check src tests && uv run ruff format --check src tests && uv run ty check .",
    "lint:rust": "cd src-tauri && cargo fmt --check && cargo clippy --all-targets -- -D warnings",
    "format:py": "cd sidecar && uv run ruff format src tests",
    "format:rust": "cd src-tauri && cargo fmt"
  },
