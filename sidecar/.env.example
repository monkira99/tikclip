# TikClip sidecar — copy to `.env` next to this file (`sidecar/.env`) and adjust.
# The app loads it automatically on startup (Pydantic Settings), including when Tauri spawns Python.
# You do not need `uv run --env-file` unless you prefer a different file path.
# Prefix for all variables: TIKCLIP_
#
# Desktop (Tauri): Settings saved in SQLite are injected as process env and override this file for:
# TIKCLIP_STORAGE_PATH, TIKCLIP_POLL_INTERVAL_SECONDS, TIKCLIP_MAX_CONCURRENT_RECORDINGS,
# TIKCLIP_CLIP_MIN_DURATION, TIKCLIP_CLIP_MAX_DURATION, TIKCLIP_MAX_DURATION_MINUTES (recording cap),
# TIKCLIP_STORAGE_QUOTA_GB (optional),
# TIKCLIP_PRODUCT_VECTOR_ENABLED, TIKCLIP_GEMINI_API_KEY, TIKCLIP_GEMINI_EMBEDDING_MODEL,
# TIKCLIP_GEMINI_EMBEDDING_DIMENSIONS,
# TIKCLIP_AUTO_TAG_CLIP_PRODUCT_ENABLED, TIKCLIP_AUTO_TAG_CLIP_FRAME_COUNT,
# TIKCLIP_AUTO_TAG_CLIP_MAX_SCORE.

# --- HTTP server ---
TIKCLIP_HOST=127.0.0.1
TIKCLIP_PORT=18321
TIKCLIP_PORT_FALLBACK_RANGE_START=18322
TIKCLIP_PORT_FALLBACK_RANGE_END=18999

# --- Paths ---
# Single data root (default: ~/.tikclip from the desktop app, or configurable in Settings).
# Layout: {root}/data/app.db | {root}/clips/{user}/{date}/*.mp4 | {root}/records/{user}/{date}/*
# TIKCLIP_STORAGE_PATH=/Users/you/.tikclip

# --- Logging & debug ---
# Levels: critical | error | warning | info | debug | trace
TIKCLIP_LOG_LEVEL=info
# Use debug to print storage breakdown (GET /api/storage/stats) and cleanup steps (tikclip.storage / tikclip.cleanup).
# When true, save HTML only on live-page HTTP errors or suspected WAF/block responses (not plain offline)
# to {TIKCLIP_STORAGE_PATH}/debug/tiktok_live_html/<timestamp>_<user>.html (max ~512 KiB) and log the path.
TIKCLIP_DEBUG_TIKTOK=false

# --- TikTok HTTP (WAF / fingerprint) ---
# curl_cffi impersonates Chrome TLS (similar to tiktok-live-recorder); use httpx to force legacy client.
# TIKCLIP_TIKTOK_HTTP_BACKEND=curl_cffi
# TIKCLIP_TIKTOK_HTTP_BACKEND=httpx
# Impersonation profile for curl_cffi (e.g. chrome131, chrome136).
# TIKCLIP_TIKTOK_CURL_IMPERSONATE=chrome131
# Opt-in: call a third-party sign API (default base tikrec.com) — sends the TikTok unique_id off-device.
# TIKCLIP_TIKTOK_ROOM_SIGN_ENABLED=true
# TIKCLIP_TIKTOK_ROOM_SIGN_BASE_URL=https://tikrec.com
# Per-request timeout (seconds) for TikTok/webcast requests (default 45; was 20 before).
# TIKCLIP_TIKTOK_HTTP_TIMEOUT_SECONDS=60

# --- Watcher / TikTok polling ---
TIKCLIP_POLL_INTERVAL_SECONDS=30

# --- Recording limits ---
TIKCLIP_MAX_CONCURRENT_RECORDINGS=5
# Max duration per recording when start API does not pass max_duration_seconds (auto-record), in minutes.
TIKCLIP_MAX_DURATION_MINUTES=5
TIKCLIP_MAX_FILE_SIZE_GB=4
# Optional soft quota (GB); desktop Settings "Max storage" maps here when using the app UI.
# TIKCLIP_STORAGE_QUOTA_GB=100
TIKCLIP_RETRY_ATTEMPTS=3

# --- Post-processing (PySceneDetect / clips) ---
TIKCLIP_CLIP_MIN_DURATION=15
TIKCLIP_CLIP_MAX_DURATION=90
TIKCLIP_SCENE_THRESHOLD=30.0
TIKCLIP_AUTO_PROCESS_AFTER_RECORD=true
TIKCLIP_AUTO_CLEANUP_RAW=true
TIKCLIP_RAW_RETENTION_DAYS=7

# --- Product media vector index (zvec + Gemini embedContent) ---
# Optional CLI / dev overrides; the desktop app normally sets these from Settings → SQLite → sidecar env.
# TIKCLIP_PRODUCT_VECTOR_ENABLED=false
# TIKCLIP_GEMINI_API_KEY=
# TIKCLIP_GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
# TIKCLIP_GEMINI_EMBEDDING_DIMENSIONS=1536
# TIKCLIP_AUTO_TAG_CLIP_PRODUCT_ENABLED=false
# TIKCLIP_AUTO_TAG_CLIP_FRAME_COUNT=4
# TIKCLIP_AUTO_TAG_CLIP_MAX_SCORE=0.35
