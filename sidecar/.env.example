# TikClip sidecar — copy to `.env` next to this file (`sidecar/.env`) and adjust.
# The app loads it automatically on startup (Pydantic Settings), including when Tauri spawns Python.
# You do not need `uv run --env-file` unless you prefer a different file path.
# Prefix for all variables: TIKCLIP_
#
# Desktop (Tauri): Settings saved in SQLite are injected as process env and override this file for:
# TIKCLIP_STORAGE_PATH, TIKCLIP_POLL_INTERVAL_SECONDS, TIKCLIP_MAX_CONCURRENT_RECORDINGS,
# TIKCLIP_CLIP_MIN_DURATION, TIKCLIP_CLIP_MAX_DURATION, TIKCLIP_MAX_DURATION_MINUTES (recording cap),
# TIKCLIP_STORAGE_QUOTA_GB (optional).

# --- HTTP server ---
TIKCLIP_HOST=127.0.0.1
TIKCLIP_PORT=18321
TIKCLIP_PORT_FALLBACK_RANGE_START=18322
TIKCLIP_PORT_FALLBACK_RANGE_END=18999

# --- Paths ---
# Single data root (default: ~/.tikclip from the desktop app, or configurable in Settings).
# Layout: {root}/data/app.db | {root}/clips/{user}/{date}/*.mp4 | {root}/records/{user}/{date}/*
# TIKCLIP_STORAGE_PATH=/Users/you/.tikclip

# --- Logging & debug ---
# Levels: critical | error | warning | info | debug | trace
TIKCLIP_LOG_LEVEL=info
# When true, log a short HTML snippet if TikTok live page yields no room_id (no cookies logged).
TIKCLIP_DEBUG_TIKTOK=false

# --- Watcher / TikTok polling ---
TIKCLIP_POLL_INTERVAL_SECONDS=30

# --- Recording limits ---
TIKCLIP_MAX_CONCURRENT_RECORDINGS=5
# Max duration per recording when start API does not pass max_duration_seconds (auto-record), in minutes.
TIKCLIP_MAX_DURATION_MINUTES=5
TIKCLIP_MAX_FILE_SIZE_GB=4
# Optional soft quota (GB); desktop Settings "Max storage" maps here when using the app UI.
# TIKCLIP_STORAGE_QUOTA_GB=100
TIKCLIP_RETRY_ATTEMPTS=3

# --- Post-processing (PySceneDetect / clips) ---
TIKCLIP_CLIP_MIN_DURATION=15
TIKCLIP_CLIP_MAX_DURATION=90
TIKCLIP_SCENE_THRESHOLD=30.0
TIKCLIP_AUTO_PROCESS_AFTER_RECORD=true
TIKCLIP_AUTO_CLEANUP_RAW=true
TIKCLIP_RAW_RETENTION_DAYS=7
